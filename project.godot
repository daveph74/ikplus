; Engine configuration file.
; Triple Strike — 2.5D three-fighter karate POC. See docs/plan.md.

config_version=5

[application]

config/name="Triple Strike"
run/main_scene="res://scenes/main/main.tscn"
config/features=PackedStringArray("4.7", "Forward Plus")
config/icon="res://icon.svg"

[autoload]

GameEvents="*res://scripts/match/game_events.gd"
AudioManager="*res://scripts/match/audio_manager.gd"

[display]

window/size/viewport_width=1920
window/size/viewport_height=1080
window/stretch/mode="canvas_items"
window/stretch/aspect="expand"
window/handheld/orientation=4

[input]

move_left={
"deadzone": 0.2,
"events": [Object(InputEventKey,"device":-1,"physical_keycode":65), Object(InputEventKey,"device":-1,"physical_keycode":4194319), Object(InputEventJoypadMotion,"device":-1,"axis":0,"axis_value":-1.0)]
}
move_right={
"deadzone": 0.2,
"events": [Object(InputEventKey,"device":-1,"physical_keycode":68), Object(InputEventKey,"device":-1,"physical_keycode":4194321), Object(InputEventJoypadMotion,"device":-1,"axis":0,"axis_value":1.0)]
}
down={
"deadzone": 0.2,
"events": [Object(InputEventKey,"device":-1,"physical_keycode":83), Object(InputEventKey,"device":-1,"physical_keycode":4194322), Object(InputEventJoypadMotion,"device":-1,"axis":1,"axis_value":1.0)]
}
jump={
"deadzone": 0.2,
"events": [Object(InputEventKey,"device":-1,"physical_keycode":87), Object(InputEventKey,"device":-1,"physical_keycode":32), Object(InputEventJoypadButton,"device":-1,"button_index":0)]
}
punch={
"deadzone": 0.2,
"events": [Object(InputEventKey,"device":-1,"physical_keycode":74), Object(InputEventJoypadButton,"device":-1,"button_index":2)]
}
kick={
"deadzone": 0.2,
"events": [Object(InputEventKey,"device":-1,"physical_keycode":75), Object(InputEventJoypadButton,"device":-1,"button_index":3)]
}
block={
"deadzone": 0.2,
"events": [Object(InputEventKey,"device":-1,"physical_keycode":76), Object(InputEventJoypadButton,"device":-1,"button_index":1)]
}
pause={
"deadzone": 0.2,
"events": [Object(InputEventKey,"device":-1,"physical_keycode":4194305), Object(InputEventJoypadButton,"device":-1,"button_index":6)]
}
restart={
"deadzone": 0.2,
"events": [Object(InputEventKey,"device":-1,"physical_keycode":82), Object(InputEventJoypadButton,"device":-1,"button_index":4)]
}
debug_toggle={
"deadzone": 0.2,
"events": [Object(InputEventKey,"device":-1,"physical_keycode":4194334)]
}

[layer_names]

3d_physics/layer_1="world"
3d_physics/layer_2="fighters"
3d_physics/layer_3="hitbox"
3d_physics/layer_4="hurtbox"

[physics]

common/physics_ticks_per_second=60

[rendering]

renderer/rendering_method="forward_plus"
renderer/rendering_method.mobile="mobile"
anti_aliasing/quality/use_debanding=true
